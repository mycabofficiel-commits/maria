# Base de données PostgreSQL (Render fournit cette URL automatiquement)
DATABASE_URL=postgresql://user:password@host:5432/maria

# Sécurité JWT (générer avec: openssl rand -base64 32)
JWT_SECRET=change-me-with-a-long-random-secret

# Port du serveur (Render utilise 10000)
PORT=3000

# Auth OAuth Manus (optionnel — laisser vide pour désactiver OAuth)
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# Propriétaire super-admin (openId de ton compte)
OWNER_OPEN_ID=

# IA intégrée (optionnel)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# Email transactionnel — Resend (https://resend.com)
# 1. Créer un compte sur resend.com
# 2. Ajouter le domaine mar-ia.net et vérifier via DNS
# 3. Créer une clé API et la coller ici
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Paiements — Stripe (https://stripe.com)
# 1. Créer un compte sur stripe.com
# 2. Récupérer la clé secrète dans Dashboard > Développeurs > Clés API
# 3. Créer 3 produits (Creator 19€/mois, Pro 49€/mois, Agency 99€/mois)
#    et copier les Price ID (price_xxxxxxxx) de chaque produit
# 4. Créer un webhook : https://mar-ia.net/api/billing/webhook
#    Événements : checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
#    Copier le Signing secret ici
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CREATOR=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_AGENCY=price_xxxxxxxxxxxxxxxxxxxx
